<!--admin.wxml-->
<view class="container">
  <!-- 管理员头部 -->
  <view class="header">
    <view class="admin-info">
      <text class="admin-icon">🔧</text>
      <view class="admin-text">
        <text class="admin-title">管理后台</text>
        <text class="admin-desc">训机师学院积分管理</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="card">
    <view class="menu-title">积分管理</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="goToGrantPoints">
        <view class="menu-left">
          <text class="menu-icon">➕</text>
          <text class="menu-text">发放积分</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="goToPointsLog">
        <view class="menu-left">
          <text class="menu-icon">📊</text>
          <text class="menu-text">积分记录</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="menu-title">订单管理</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="goToVerifyOrder">
        <view class="menu-left">
          <text class="menu-icon">✅</text>
          <text class="menu-text">核销订单</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="goToOrderList">
        <view class="menu-left">
          <text class="menu-icon">📦</text>
          <text class="menu-text">订单列表</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="menu-title">商品管理</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="goToGoodsManage">
        <view class="menu-left">
          <text class="menu-icon">🛍️</text>
          <text class="menu-text">商品管理</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="goToCategoryManage">
        <view class="menu-left">
          <text class="menu-icon">📁</text>
          <text class="menu-text">分类管理</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="menu-title">用户管理</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="goToUserList">
        <view class="menu-left">
          <text class="menu-icon">👥</text>
          <text class="menu-text">学员列表</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <!-- 快速操作区 -->
  <view class="quick-actions">
    <view class="action-btn" bindtap="showGrantModal">
      <text class="action-icon">🎁</text>
      <text class="action-text">快速发积分</text>
    </view>
    <view class="action-btn" bindtap="showVerifyModal">
      <text class="action-icon">📱</text>
      <text class="action-text">扫码核销</text>
    </view>
  </view>

  <!-- 底部留白 -->
  <view class="bottom-space"></view>

  <!-- 发放积分弹窗 -->
  <view class="modal-mask" wx:if="{{showGrantModal}}" bindtap="hideGrantModal">
    <view class="modal-content grant-modal" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">发放积分</text>
        <text class="modal-close" bindtap="hideGrantModal">×</text>
      </view>
      <view class="modal-body">
        <view class="search-section">
          <view class="search-input-wrapper">
            <text class="search-icon">🔍</text>
            <input class="search-input" placeholder="搜索学员姓名" value="{{searchKeyword}}" bindinput="onSearchInput" />
            <button class="search-btn" size="mini" bindtap="searchUser">搜索</button>
          </view>
          <view class="search-results" wx:if="{{searchResults.length > 0}}">
            <view class="search-item" wx:for="{{searchResults}}" wx:key="_id" bindtap="selectUser" data-user="{{item}}">
              <image class="search-avatar" src="{{item.avatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
              <view class="search-info">
                <text class="search-name">{{item.name}}</text>
                <text class="search-points">当前积分：{{item.points}}</text>
              </view>
            </view>
          </view>
        </view>
        <view class="selected-user" wx:if="{{selectedUser}}">
          <image class="selected-avatar" src="{{selectedUser.avatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
          <view class="selected-info">
            <text class="selected-name">{{selectedUser.name}}</text>
            <text class="selected-points">当前积分：{{selectedUser.points}}</text>
          </view>
        </view>
        <view class="form-section" wx:if="{{selectedUser}}">
          <view class="form-item">
            <text class="form-label">积分数量</text>
            <input class="form-input" type="number" placeholder="请输入积分数量" value="{{grantPoints}}" bindinput="onPointsInput" />
          </view>
          <view class="form-item">
            <text class="form-label">发放事由</text>
            <input class="form-input" placeholder="请输入发放事由" value="{{grantReason}}" bindinput="onReasonInput" />
          </view>
        </view>
      </view>
      <view class="modal-footer">
        <button class="modal-btn modal-btn-cancel" bindtap="hideGrantModal">取消</button>
        <button class="modal-btn modal-btn-confirm" bindtap="confirmGrant" disabled="{{!selectedUser || !grantPoints}}">确认发放</button>
      </view>
    </view>
  </view>

  <!-- 核销弹窗 -->
  <view class="modal-mask" wx:if="{{showVerifyModal}}" bindtap="hideVerifyModal">
    <view class="modal-content verify-modal" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">核销订单</text>
        <text class="modal-close" bindtap="hideVerifyModal">×</text>
      </view>
      <view class="modal-body">
        <view class="verify-section">
          <view class="form-item">
            <text class="form-label">兑换码</text>
            <input class="form-input" placeholder="请输入或扫描兑换码" value="{{exchangeCode}}" bindinput="onCodeInput" />
          </view>
          <button class="scan-btn" bindtap="scanCode">
            <text class="scan-icon">📷</text>
            扫码
          </button>
        </view>
        <view class="order-info" wx:if="{{verifyOrder}}">
          <view class="order-info-header">
            <text class="order-info-title">订单信息</text>
            <text class="order-status {{verifyOrder.status}}">{{getOrderStatusText(verifyOrder.status)}}</text>
          </view>
          <view class="order-info-content">
            <image class="order-goods-image" src="{{verifyOrder.goodsImage || '/images/default-goods.png'}}" mode="aspectFill"></image>
            <view class="order-goods-info">
              <text class="order-goods-name">{{verifyOrder.goodsName}}</text>
              <text class="order-goods-points">{{verifyOrder.points}} 积分</text>
            </view>
          </view>
          <view class="order-user-info">
            <text class="order-user">收货人：{{verifyOrder.address.name}}</text>
            <text class="order-phone">电话：{{verifyOrder.address.phone}}</text>
          </view>
        </view>
      </view>
      <view class="modal-footer" wx:if="{{verifyOrder && verifyOrder.status === 'pending'}}">
        <button class="modal-btn modal-btn-cancel" bindtap="hideVerifyModal">取消</button>
        <button class="modal-btn modal-btn-confirm" bindtap="confirmVerify">确认核销</button>
      </view>
    </view>
  </view>
</view>
