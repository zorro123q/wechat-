<!--profile.wxml-->
<view class="container">
  <!-- 用户信息头部 -->
  <view class="header">
    <view class="user-info">
      <image class="avatar" src="{{userInfo.avatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
      <view class="user-detail">
        <view class="user-name-row">
          <text class="user-name">{{userInfo.name || '未设置姓名'}}</text>
          <view class="level-badge level-{{levelInfo.key}}">
            <text class="level-text">{{levelInfo.name}}</text>
          </view>
        </view>
        <text class="user-phone">{{userInfo.phone ? maskPhone(userInfo.phone) : '未绑定手机号'}}</text>
      </view>
    </view>
    <view class="points-card">
      <view class="points-item">
        <text class="points-value">{{formatPoints(userInfo.points)}}</text>
        <text class="points-label">可用积分</text>
      </view>
      <view class="points-divider"></view>
      <view class="points-item">
        <text class="points-value">{{formatPoints(userInfo.totalPoints)}}</text>
        <text class="points-label">累计积分</text>
      </view>
    </view>
  </view>

  <!-- 等级进度 -->
  <view class="card" wx:if="{{levelInfo.nextLevel}}">
    <view class="level-progress-section">
      <view class="level-progress-header">
        <text class="level-title">我的等级</text>
        <text class="level-next" bindtap="showLevelGuide">升级攻略 ></text>
      </view>
      <view class="level-progress-bar">
        <view class="level-badge-small level-{{levelInfo.key}}">
          <text>{{levelInfo.name}}</text>
        </view>
        <view class="progress-container">
          <view class="progress-bar">
            <view class="progress-fill" style="width: {{levelInfo.progress}}%;"></view>
          </view>
        </view>
        <view class="level-badge-small level-{{levelInfo.nextLevel.key}}">
          <text>{{levelInfo.nextLevel.name}}</text>
        </view>
      </view>
      <view class="level-tip">
        再获得 <text class="text-primary font-bold">{{formatPoints(levelInfo.pointsToNext)}}</text> 积分即可升级到{{levelInfo.nextLevel.name}}
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="card">
    <view class="menu-list">
      <view class="menu-item" bindtap="goToPointsDetail">
        <view class="menu-left">
          <text class="menu-icon">📊</text>
          <text class="menu-text">积分明细</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="goToExchangeRecords">
        <view class="menu-left">
          <text class="menu-icon">📦</text>
          <text class="menu-text">兑换记录</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="goToAddress">
        <view class="menu-left">
          <text class="menu-icon">📍</text>
          <text class="menu-text">收货地址</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <!-- 更多菜单 -->
  <view class="card">
    <view class="menu-list">
      <view class="menu-item" bindtap="contactService">
        <view class="menu-left">
          <text class="menu-icon">💬</text>
          <text class="menu-text">联系客服</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="showAbout">
        <view class="menu-left">
          <text class="menu-icon">ℹ️</text>
          <text class="menu-text">关于我们</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <!-- 管理员入口 -->
  <view class="card" wx:if="{{isAdmin}}">
    <view class="menu-list">
      <view class="menu-item admin-menu" bindtap="goToAdmin">
        <view class="menu-left">
          <text class="menu-icon">🔧</text>
          <text class="menu-text">管理后台</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <!-- 底部留白 -->
  <view class="bottom-space"></view>

  <!-- 等级说明弹窗 -->
  <view class="modal-mask" wx:if="{{showLevelModal}}" bindtap="hideLevelGuide">
    <view class="modal-content level-modal" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">等级说明</text>
        <text class="modal-close" bindtap="hideLevelGuide">×</text>
      </view>
      <view class="modal-body">
        <view class="level-item" wx:for="{{levels}}" wx:key="key">
          <view class="level-icon-wrapper level-{{item.key}}">
            <text class="level-emoji">{{item.key === 'senior' ? '👑' : item.key === 'intermediate' ? '⭐' : '🌱'}}</text>
          </view>
          <view class="level-detail">
            <text class="level-name">{{item.name}}</text>
            <text class="level-require">{{item.minPoints}}积分起</text>
          </view>
        </view>
        <view class="divider"></view>
        <view class="privileges">
          <text class="privileges-title">等级特权</text>
          <view class="privilege-item">
            <text class="privilege-dot"></text>
            <text class="privilege-text">初级训机师：享受基础兑换权益</text>
          </view>
          <view class="privilege-item">
            <text class="privilege-dot"></text>
            <text class="privilege-text">中级训机师：部分商品享受积分折扣</text>
          </view>
          <view class="privilege-item">
            <text class="privilege-dot"></text>
            <text class="privilege-text">高级训机师：VIP专属商品、优先兑换权</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
