/* mall.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 搜索栏 */
.search-bar {
  background: #ffffff;
  padding: 20rpx 30rpx;
  position: sticky;
  top: 0;
  z-index: 100;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 48rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.search-clear {
  font-size: 36rpx;
  color: #999999;
  line-height: 1;
  padding: 0 8rpx;
}

/* 分类导航 */
.category-scroll {
  background: #ffffff;
  white-space: nowrap;
}

.category-list {
  display: flex;
  padding: 20rpx 30rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 40rpx;
  padding: 8rpx 0;
}

.category-item:last-child {
  margin-right: 0;
}

.category-item.active .category-text {
  color: #1890ff;
  font-weight: bold;
}

.category-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #1890ff;
  border-radius: 2rpx;
}

.category-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.category-text {
  font-size: 26rpx;
  color: #666666;
}

/* 积分提示 */
.points-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #fff7e6 0%, #ffe7ba 100%);
  margin: 20rpx 30rpx;
  padding: 20rpx;
  border-radius: 16rpx;
}

.points-tip-text {
  font-size: 26rpx;
  color: #666666;
}

.points-tip-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff4d4f;
  margin-left: 8rpx;
}

/* 商品列表 */
.goods-container {
  padding: 0 20rpx 20rpx;
}

.goods-grid {
  display: flex;
  flex-wrap: wrap;
  margin: -10rpx;
}

.goods-card {
  width: calc(50% - 20rpx);
  margin: 10rpx;
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
}

.goods-image {
  width: 100%;
  height: 300rpx;
  background: #f5f5f5;
}

.goods-tag {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  background: linear-gradient(135deg, #ff4d4f 0%, #cf1322 100%);
  color: #ffffff;
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.goods-info {
  padding: 20rpx;
}

.goods-name {
  font-size: 28rpx;
  color: #333333;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.4;
  min-height: 78rpx;
}

.goods-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.goods-price {
  display: flex;
  align-items: baseline;
}

.points {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff4d4f;
}

.points-unit {
  font-size: 22rpx;
  color: #ff4d4f;
  margin-left: 4rpx;
}

.original-points {
  font-size: 22rpx;
  color: #999999;
  text-decoration: line-through;
  margin-left: 8rpx;
}

.goods-stock {
  font-size: 22rpx;
  color: #999999;
}

.out-of-stock {
  color: #ff4d4f;
}

.exchange-btn {
  margin: 0 20rpx 20rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #ffffff;
  font-size: 26rpx;
  text-align: center;
  padding: 16rpx;
  border-radius: 40rpx;
}

/* 空状态 */
.empty-container {
  padding: 120rpx 0;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  margin-top: 20rpx;
  display: block;
}

/* 加载状态 */
.loading-container {
  padding: 80rpx 0;
  text-align: center;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #1890ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin: 0 auto;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 26rpx;
  color: #999999;
  margin-top: 20rpx;
  display: block;
}

/* 没有更多 */
.no-more {
  text-align: center;
  padding: 40rpx 0;
  color: #999999;
  font-size: 24rpx;
}

/* 底部留白 */
.bottom-space {
  height: 40rpx;
}
