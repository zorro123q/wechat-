        </view>
      </view>
    </view>
    
    <!-- 等级3 -->
    <view class="level-item level-3">
      <view class="level-header">
        <text class="level-number">等级3</text>
        <text class="level-name">高级权限</text>
      </view>
      <view class="level-privileges">
        <view class="privilege-item">
          <text class="privilege-dot"></text>
