<view class="page">
  <view class="bg">
    <image class="bg-img" src="/images/login-bg.png" mode="aspectFit"></image>
  </view>
  <view class="bg-mask"></view>
  <view class="brand">
    <view class="brand-logo-wrap">
      <view class="brand-logo-ring">
        <image class="brand-logo" src="/images/logo.png" mode="aspectFill"></image>
      </view>
    </view>
    <text class="brand-title">科讯嘉联</text>
    <text class="brand-subtitle">训机师学苑</text>
    <view class="brand-pill">
      <text class="brand-pill-text">科技赋能 · 学苑平台</text>
    </view>
  </view>
  <view class="panel">
    <view class="panel-head">
      <view class="tabs">
        <view class="tab {{activeTab === 'code' ? 'active' : ''}}" data-tab="code" bindtap="switchTab">
          验证码登录/注册
        </view>
        <view class="tab {{activeTab === 'password' ? 'active' : ''}}" data-tab="password" bindtap="switchTab">
          密码登录/注册
        </view>
      </view>
    </view>
    <view class="panel-body">
      <view class="tips">
        <text wx:if="{{activeTab === 'code'}}">未注册手机号验证码登录将自动创建账号</text>
        <text wx:else>{{passwordMode === 'register' ? '手机号+密码注册，注册成功后需要完善资料' : '手机号+密码登录'}}</text>
      </view>
      <view class="form">
        <view class="field">
          <view class="field-head">
            <text class="field-icon">📱</text>
            <text class="field-label">手机号</text>
          </view>
          <input class="field-input" placeholder="请输入您的手机号" type="number" value="{{phone}}" bindinput="onPhoneInput" maxlength="11" />
        </view>
        <view wx:if="{{activeTab === 'code'}}" class="field">
          <view class="field-head">
            <text class="field-icon">🧾</text>
            <text class="field-label">验证码</text>
          </view>
          <view class="field-row">
            <input class="field-input field-input-flex" placeholder="请输入验证码" type="number" value="{{code}}" bindinput="onCodeInput" maxlength="6" />
            <button class="field-btn" disabled="{{isSending || countdown > 0}}" bindtap="sendCode">
              {{countdown > 0 ? countdown + 's' : '获取验证码'}}
            </button>
          </view>
        </view>
        <view wx:if="{{activeTab === 'password'}}" class="field">
          <view class="field-head">
            <text class="field-icon">🔒</text>
            <text class="field-label">密码</text>
          </view>
          <view class="password-mode">
            <text class="mode-btn {{passwordMode === 'login' ? 'active' : ''}}" data-mode="login" bindtap="switchPasswordMode">
              登录
            </text>
            <text class="mode-btn {{passwordMode === 'register' ? 'active' : ''}}" data-mode="register" bindtap="switchPasswordMode">
              注册
            </text>
          </view>
          <input class="field-input" placeholder="{{passwordMode === 'register' ? '请设置 6 位以上密码' : '请输入密码'}}" password value="{{password}}" bindinput="onPasswordInput" />
        </view>
        <view class="agreement">
          <checkbox-group bindchange="onAgreeChange">
            <label class="agree-label">
              <checkbox value="agree" checked="{{agree}}" />
              <view class="agree-text">
                <text>我已阅读并同意</text>
                <text class="agree-link">《服务协议》</text>
              </view>
            </label>
          </checkbox-group>
        </view>
        <button class="submit-btn" disabled="{{!agree || isLogging}}" loading="{{isLogging}}" bindtap="submit">
          {{activeTab === 'code' ? '登录/注册' : (passwordMode === 'register' ? '注册' : '登录')}}
        </button>
        <view class="support">
          <text class="support-text">客服电话（8:00-17:00）：400-xxx-xxxx</text>
          <text class="support-link" bindtap="contactService">联系在线客服</text>
        </view>
      </view>
    </view>
  </view>
</view>