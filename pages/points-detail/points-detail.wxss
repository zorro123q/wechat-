/* points-detail.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 积分概览 */
.overview-card {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  padding: 40rpx 30rpx;
}

.overview-header {
  margin-bottom: 20rpx;
}

.overview-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.overview-points {
  margin-bottom: 30rpx;
}

.points-value {
  font-size: 72rpx;
  font-weight: bold;
  color: #ffffff;
}

.overview-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding-top: 30rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stat-value {
  font-size: 32rpx;
  font-weight: bold;
  margin-top: 8rpx;
}

.stat-earn {
  color: #b7eb8f;
}

.stat-spend {
  color: #ffadd2;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.2);
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  background: #ffffff;
  padding: 20rpx 30rpx;
}

.filter-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  position: relative;
}

.filter-tab.active .filter-text {
  color: #1890ff;
  font-weight: bold;
}

.filter-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #1890ff;
  border-radius: 2rpx;
}

.filter-text {
  font-size: 28rpx;
  color: #666666;
}

/* 明细列表 */
.list-container {
  padding: 20rpx 30rpx;
}

.log-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.log-left {
  display: flex;
  align-items: center;
  flex: 1;
  margin-right: 20rpx;
}

.log-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.log-icon.earn {
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
  color: #ffffff;
}

.log-icon.spend {
  background: linear-gradient(135deg, #ff4d4f 0%, #cf1322 100%);
  color: #ffffff;
}

.log-info {
  margin-left: 20rpx;
  flex: 1;
  min-width: 0;
}

.log-reason {
  font-size: 28rpx;
  color: #333333;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.log-time {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
  display: block;
}

.log-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
}

.log-amount {
  font-size: 32rpx;
  font-weight: bold;
}

.log-amount.earn {
  color: #52c41a;
}

.log-amount.spend {
  color: #ff4d4f;
}

.log-balance {
  font-size: 22rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* 空状态 */
.empty-container {
  padding: 120rpx 0;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  opacity: 0.5;
  display: block;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  margin-top: 20rpx;
  display: block;
}

/* 加载状态 */
.loading-container {
  padding: 80rpx 0;
  text-align: center;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #1890ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin: 0 auto;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 26rpx;
  color: #999999;
  margin-top: 20rpx;
  display: block;
}

/* 没有更多 */
.no-more {
  text-align: center;
  padding: 40rpx 0;
  color: #999999;
  font-size: 24rpx;
}

/* 底部留白 */
.bottom-space {
  height: 40rpx;
}
