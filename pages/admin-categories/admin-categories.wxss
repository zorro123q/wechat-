.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx 20rpx 40rpx;
}

.toolbar {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.title {
  font-size: 30rpx;
  font-weight: 800;
  color: #333;
}

.count {
  font-size: 24rpx;
  color: #999;
}

.list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  gap: 16rpx;
}

.row:last-child {
  border-bottom: none;
}

.row-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.name {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

.meta {
  font-size: 24rpx;
  color: #666;
}

.row-actions {
  display: flex;
  gap: 10rpx;
}

.btn.danger {
  color: #ff4d4f;
}

.empty,
.loading {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
  color: #999;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal {
  width: 680rpx;
  max-height: 80vh;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.modal-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #333;
  padding: 24rpx 24rpx 0;
}

.form {
  padding: 20rpx 24rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.form-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx 0;
}

.label {
  width: 120rpx;
  font-size: 26rpx;
  color: #666;
}

.input {
  flex: 1;
  height: 72rpx;
  background: #f6f7fb;
  border-radius: 12rpx;
  padding: 0 18rpx;
  font-size: 26rpx;
  color: #333;
  display: flex;
  align-items: center;
}

.modal-actions {
  display: flex;
  gap: 16rpx;
  padding: 18rpx 24rpx 24rpx;
}

.modal-actions .btn {
  flex: 1;
}

.modal-actions .btn.primary {
  background: #1890ff;
  color: #fff;
}

