/* index.wxss */
.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 顶部欢迎区域 */
.header {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  padding: 30rpx 30rpx 60rpx;
}

.header-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.welcome {
  display: flex;
  flex-direction: column;
}

.welcome-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
}

.welcome-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.logo-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.14);
  border: 2rpx solid rgba(255, 255, 255, 0.22);
  box-shadow: 0 10rpx 26rpx rgba(0, 0, 0, 0.12);
}

.logo {
  width: 100%;
  height: 100%;
}

/* 用户信息卡片 */
.user-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin: -30rpx 30rpx 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #f0f0f0;
}

.user-detail {
  flex: 1;
  margin-left: 24rpx;
}

.user-name-row {
  display: flex;
  align-items: center;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.level-badge {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-left: 16rpx;
}

.level-badge.level-junior {
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
}

.level-badge.level-intermediate {
  background: linear-gradient(135deg, #faad14 0%, #d48806 100%);
}

.level-badge.level-senior {
  background: linear-gradient(135deg, #f5222d 0%, #cf1322 100%);
}

.level-text {
  font-size: 20rpx;
  color: #ffffff;
}

.user-id {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.points-section {
  display: flex;
  align-items: center;
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.points-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.points-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #1890ff;
}

.points-label {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.points-divider {
  width: 1rpx;
  height: 60rpx;
  background: #eeeeee;
}

/* 快捷入口 */
.quick-menu {
  display: flex;
  justify-content: space-around;
}

.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.menu-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.points-icon {
  background: linear-gradient(135deg, #e6f7ff 0%, #bae7ff 100%);
}

.record-icon {
  background: linear-gradient(135deg, #f6ffed 0%, #d9f7be 100%);
}

.level-icon {
  background: linear-gradient(135deg, #fffbe6 0%, #ffe58f 100%);
}

.mall-icon {
  background: linear-gradient(135deg, #fff1f0 0%, #ffccc7 100%);
}

.menu-text {
  font-size: 24rpx;
  color: #333333;
  margin-top: 12rpx;
}

/* 章节标题 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.section-more {
  font-size: 24rpx;
  color: #999999;
}

/* 公告轮播 */
.notice-swiper {
  height: 60rpx;
}

.notice-item {
  display: flex;
  align-items: center;
}

.notice-tag {
  padding: 4rpx 12rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #ffffff;
  font-size: 20rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.notice-text {
  font-size: 26rpx;
  color: #333333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 等级进度 */
.level-progress {
  padding: 10rpx 0;
}

.level-info-row {
  display: flex;
  align-items: center;
}

.current-level,
.next-level {
  font-size: 24rpx;
  color: #666666;
  flex-shrink: 0;
}

.progress-container {
  flex: 1;
  display: flex;
  align-items: center;
  margin: 0 20rpx;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #1890ff 0%, #096dd9 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 22rpx;
  color: #999999;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.level-tip {
  font-size: 24rpx;
  color: #666666;
  text-align: center;
  margin-top: 20rpx;
}

/* 商品列表 */
.goods-list {
  display: flex;
  flex-wrap: wrap;
  margin: -10rpx;
}

.goods-item {
  width: 50%;
  padding: 10rpx;
  box-sizing: border-box;
}

.goods-image {
  width: 100%;
  height: 240rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
}

.goods-info {
  padding: 16rpx 8rpx 0;
}

.goods-name {
  font-size: 26rpx;
  color: #333333;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

.goods-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.goods-points {
  font-size: 28rpx;
  font-weight: bold;
  color: #ff4d4f;
}

.goods-sold {
  font-size: 22rpx;
  color: #999999;
}

.empty-tip {
  width: 100%;
  text-align: center;
  padding: 60rpx 0;
  color: #999999;
  font-size: 26rpx;
}

/* 底部留白 */
.bottom-space {
  height: 40rpx;
}

/* 弹窗遮罩 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-content {
  width: 600rpx;
  max-height: 80vh;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.modal-close {
  font-size: 48rpx;
  color: #999999;
  line-height: 1;
}

.modal-body {
  padding: 30rpx;
  max-height: 60vh;
  overflow-y: auto;
}

/* 等级说明弹窗 */
.level-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.level-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.level-icon-wrapper.level-junior {
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
}

.level-icon-wrapper.level-intermediate {
  background: linear-gradient(135deg, #faad14 0%, #d48806 100%);
}

.level-icon-wrapper.level-senior {
  background: linear-gradient(135deg, #f5222d 0%, #cf1322 100%);
}

.level-icon-wrapper .level-emoji {
  font-size: 40rpx;
  color: #ffffff;
  position: relative;
  bottom: 30rpx;
}

.level-detail {
  flex: 1;
  margin-left: 20rpx;
}

.level-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.level-require {
  font-size: 24rpx;
  color: #999999;
  margin-top: 6rpx;
}

.privileges-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  display: block;
}

.privilege-item {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
}

.privilege-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #1890ff;
  margin-top: 10rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.privilege-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

/* 等级展示 */
.level-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.level-badge-large {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.level-badge-large .level-emoji {
  font-size: 120rpx;
  line-height: 1;
  position: relative;
  bottom: 50rpx;
}

.level-badge-large .level-name-large {
  display: none;
}

.level-tip-text {
  font-size: 24rpx;
  color: #999999;
  text-align: center;
  line-height: 1.6;
}
