.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx 20rpx 40rpx;
}

.toolbar {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.search {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.search-input {
  flex: 1;
  height: 72rpx;
  background: #f6f7fb;
  border-radius: 12rpx;
  padding: 0 18rpx;
  font-size: 26rpx;
}

.search-btn {
  height: 72rpx;
  line-height: 72rpx;
}

.filters {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
  align-items: center;
}

.filter {
  height: 64rpx;
  line-height: 64rpx;
  background: #f6f7fb;
  border-radius: 12rpx;
  padding: 0 18rpx;
  font-size: 26rpx;
  color: #333;
}

.list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.row {
  display: flex;
  gap: 16rpx;
  padding: 22rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.row:last-child {
  border-bottom: none;
}

.avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: #f0f0f0;
}

.row-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.name {
  font-size: 28rpx;
  font-weight: 800;
  color: #333;
}

.phone {
  font-size: 24rpx;
  color: #666;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  color: #fff;
}

.tag.earn {
  background: #52c41a;
}

.tag.spend {
  background: #ff4d4f;
}

.meta {
  display: flex;
  gap: 16rpx;
  align-items: center;
  flex-wrap: wrap;
}

.amount {
  font-size: 26rpx;
  font-weight: 800;
}

.amount.earn {
  color: #52c41a;
}

.amount.spend {
  color: #ff4d4f;
}

.balance,
.time {
  font-size: 22rpx;
  color: #999;
}

.reason {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

.empty,
.loading,
.more {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
  color: #999;
}
