.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx 30rpx 40rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.header-count {
  font-size: 26rpx;
  color: #999;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 26rpx 26rpx;
}

.upload-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.upload-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.upload-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.upload-desc {
  font-size: 24rpx;
  color: #999;
}

.upload-btn {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 28rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.upload-btn::after {
  border: none;
}

.upload-btn[disabled] {
  background: rgba(15, 31, 58, 0.18);
  color: rgba(255, 255, 255, 0.9);
}

.list-card {
  margin-top: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.upload-item {
  display: flex;
  align-items: center;
  padding: 24rpx 26rpx;
  border-bottom: 1rpx solid #f0f0f0;
  gap: 18rpx;
}

.upload-item:last-child {
  border-bottom: none;
}

.thumb {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  background: #f0f0f0;
}

.info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.actions {
  margin-left: auto;
}

.delete-btn {
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 18rpx;
  border-radius: 12rpx;
  background: rgba(255, 77, 79, 0.12);
  color: #ff4d4f;
  font-size: 24rpx;
  font-weight: 700;
}

.delete-btn::after {
  border: none;
}

.name {
  font-size: 28rpx;
  color: #333;
  font-weight: 700;
}

.date {
  font-size: 24rpx;
  color: #999;
}

.empty,
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 160rpx;
  color: #999;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #1890ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 26rpx;
  margin-top: 20rpx;
}