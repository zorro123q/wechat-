.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx 20rpx 40rpx;
}

.toolbar {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.search {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.search-input {
  flex: 1;
  height: 72rpx;
  background: #f6f7fb;
  border-radius: 12rpx;
  padding: 0 18rpx;
  font-size: 26rpx;
}

.search-btn {
  height: 72rpx;
  line-height: 72rpx;
}

.filters {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
  align-items: center;
}

.filter {
  height: 64rpx;
  line-height: 64rpx;
  background: #f6f7fb;
  border-radius: 12rpx;
  padding: 0 18rpx;
  font-size: 26rpx;
  color: #333;
}

.list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.row {
  display: flex;
  gap: 16rpx;
  padding: 22rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.row:last-child {
  border-bottom: none;
}

.thumb {
  width: 90rpx;
  height: 90rpx;
  border-radius: 14rpx;
  background: #f0f0f0;
}

.main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.line1 {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.goods {
  font-size: 28rpx;
  font-weight: 800;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.line2,
.line3,
.line4 {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  flex-wrap: wrap;
}

.right-col {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
}

.status {
  font-size: 22rpx;
  color: #666;
  font-weight: 700;
}

.status.status-pending {
  color: #fa8c16;
}

.status.status-shipped {
  color: #1890ff;
}

.status.status-completed {
  color: #52c41a;
}

.status.status-cancelled {
  color: #8c8c8c;
}

.user {
  font-size: 24rpx;
  color: #666;
}

.points {
  font-size: 24rpx;
  font-weight: 800;
  color: #ff4d4f;
}

.meta {
  font-size: 22rpx;
  color: #999;
}

.empty,
.loading,
.more {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
  color: #999;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal {
  width: 680rpx;
  max-height: 80vh;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.modal-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #333;
  padding: 24rpx 24rpx 0;
}

.detail {
  padding: 20rpx 24rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.detail-row {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 12rpx 0;
}

.k {
  width: 120rpx;
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
}

.v {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
  word-break: break-all;
}

.v-right {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.copy {
  font-size: 24rpx;
  color: #1890ff;
  flex-shrink: 0;
}

.detail-card {
  margin-top: 16rpx;
  background: #f6f7fb;
  border-radius: 12rpx;
  padding: 16rpx;
}

.detail-card-title {
  font-size: 26rpx;
  font-weight: 800;
  color: #333;
  margin-bottom: 10rpx;
}

.detail-card-line {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

.input {
  flex: 1;
  height: 72rpx;
  background: #ffffff;
  border-radius: 12rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
  color: #333;
}

.modal-actions {
  padding: 18rpx 24rpx 24rpx;
  display: flex;
  gap: 16rpx;
}

.modal-actions .btn {
  flex: 1;
}

.modal-actions .btn.primary {
  background: #1890ff;
  color: #fff;
}

.modal-actions .btn.danger {
  color: #ff4d4f;
}