<view class="container">
  <view class="filter-bar">
    <input class="search-input" placeholder="搜索学员姓名" value="{{keyword}}" bindinput="onKeywordInput" />
    <picker class="level-picker" mode="selector" value="{{levelIndex}}" range="{{levelOptions}}" bindchange="onLevelChange">
      <view class="picker-text">{{levelLabel}}</view>
    </picker>
    <view class="export-btn" bindtap="exportUsers">导出</view>
  </view>
  <view class="list">
    <view class="user-item" wx:for="{{list}}" wx:key="_id" bindtap="showDetail" data-user="{{item}}">
      <image class="avatar" src="{{item.avatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
      <view class="info">
        <view class="row">
          <text class="name">{{item.name || '未命名'}}</text>
          <text class="badge level-{{item.level || 'junior'}}">{{item.level || 'junior'}}</text>
        </view>
        <view class="meta">
          <text class="phone">手机号：{{item.phone || '--'}}</text>
          <text class="points">积分：{{item.points || 0}} / {{item.totalPoints || 0}}</text>
        </view>
      </view>
    </view>
    <view class="empty" wx:if="{{!loading && list.length === 0}}">暂无数据</view>
  </view>
  <view class="load-more" wx:if="{{hasMore && !loading}}" bindtap="loadMore">加载更多</view>
  <view class="loading" wx:if="{{loading}}">加载中...</view>
</view>
<view class="modal-mask" wx:if="{{showDetail}}" bindtap="hideDetail">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">学员详情</text>
      <text class="modal-close" bindtap="hideDetail">×</text>
    </view>
    <scroll-view class="modal-body" scroll-y>
      <view class="detail-row">
        <text class="detail-label">姓名</text>
        <text class="detail-value">{{detailUser.name || '--'}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">手机号</text>
        <text class="detail-value">{{detailUser.phone || '--'}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">等级</text>
        <text class="detail-value">{{detailUser.level || '--'}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">可用积分</text>
        <text class="detail-value">{{detailUser.points || 0}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">累计积分</text>
        <text class="detail-value">{{detailUser.totalPoints || 0}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">学校</text>
        <text class="detail-value">{{detailUser.school || '--'}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">学位</text>
        <text class="detail-value">{{detailUser.degree || '--'}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">公司</text>
        <text class="detail-value">{{detailUser.company || '--'}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">职位</text>
        <text class="detail-value">{{detailUser.role || '--'}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">工作经验</text>
        <text class="detail-value">{{detailUser.experience || '--'}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">培训意向</text>
        <text class="detail-value">{{detailUser.trainingIntention || '--'}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">身份证号</text>
        <text class="detail-value">{{detailUser.idCard || '--'}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">推荐码</text>
        <text class="detail-value">{{detailUser.referralCode || '--'}}</text>
      </view>
    </scroll-view>
  </view>
</view>