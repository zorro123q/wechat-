.container {
    min-height: 100vh;
    background: #f5f5f5;
    padding: 20rpx 30rpx
}

.filter-bar {
    display: flex;
    align-items: center;
    margin-bottom: 16rpx
}

.search-input {
    flex: 1;
    background: #fff;
    border-radius: 12rpx;
    padding: 16rpx 20rpx;
    font-size: 28rpx;
    margin-right: 12rpx
}

.level-picker {
    width: 220rpx;
    background: #fff;
    border-radius: 12rpx;
    padding: 16rpx 20rpx
}

.picker-text {
    font-size: 26rpx;
    color: #333
}

.export-btn {
    margin-left: 12rpx;
    background: #1890ff;
    color: #fff;
    border-radius: 12rpx;
    padding: 16rpx 20rpx;
    font-size: 26rpx;
    flex-shrink: 0
}

.list {
    background: #fff;
    border-radius: 16rpx;
    overflow: hidden
}

.user-item {
    display: flex;
    align-items: center;
    padding: 20rpx 16rpx;
    border-bottom: 1rpx solid #f0f0f0
}

.user-item:last-child {
    border-bottom: none
}

.avatar {
    width: 88rpx;
    height: 88rpx;
    border-radius: 50%;
    background: #f0f0f0;
    margin-right: 16rpx
}

.info {
    flex: 1
}

.row {
    display: flex;
    align-items: center;
    justify-content: space-between
}

.name {
    font-size: 30rpx;
    font-weight: 600;
    color: #333
}

.badge {
    padding: 6rpx 12rpx;
    border-radius: 16rpx;
    color: #fff;
    font-size: 22rpx
}

.badge.level-junior {
    background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%)
}

.badge.level-intermediate {
    background: linear-gradient(135deg, #faad14 0%, #d48806 100%)
}

.badge.level-senior {
    background: linear-gradient(135deg, #f5222d 0%, #cf1322 100%)
}

.meta {
    font-size: 24rpx;
    color: #666;
    margin-top: 6rpx;
    display: flex;
    justify-content: space-between
}

.empty,
.loading,
.load-more {
    text-align: center;
    padding: 26rpx 0;
    color: #999
}

.load-more {
    color: #1890ff
}

.modal-mask {
    position: fixed;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    background: rgba(0, 0, 0, .5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 999
}

.modal-content {
    width: 640rpx;
    max-height: 80vh;
    background: #fff;
    border-radius: 24rpx;
    overflow: hidden
}

.modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24rpx 30rpx;
    border-bottom: 1rpx solid #f0f0f0
}

.modal-title {
    font-size: 30rpx;
    font-weight: 600;
    color: #333
}

.modal-close {
    font-size: 44rpx;
    color: #999;
    line-height: 1
}

.modal-body {
    max-height: 70vh;
    padding: 10rpx 30rpx 24rpx
}

.detail-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 18rpx 0;
    border-bottom: 1rpx solid #f7f7f7
}

.detail-row:last-child {
    border-bottom: none
}

.detail-label {
    font-size: 26rpx;
    color: #666;
    flex-shrink: 0
}

.detail-value {
    font-size: 26rpx;
    color: #333;
    flex: 1;
    margin-left: 20rpx;
    text-align: left;
    white-space: normal;
    word-break: break-all;
    overflow-wrap: anywhere
}