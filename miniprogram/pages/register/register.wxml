<view class="container">
  <form bindsubmit="submitForm" class="register-form">
    <!-- 姓名 -->
    <view class="form-item">
      <text class="label required">姓名</text>
      <input 
        class="input" 
        data-name="name" 
        placeholder="请输入姓名" 
        value="{{formData.name}}" 
        bindinput="handleInput"
      />
    </view>

    <!-- 手机号 -->
    <view class="form-item">
      <text class="label required">手机号</text>
      <input 
        class="input" 
        data-name="phone" 
        placeholder="请输入手机号" 
        value="{{formData.phone}}" 
        bindinput="handleInput"
        type="number"
      />
    </view>

    <!-- 学校 -->
    <view class="form-item">
      <text class="label required">学校</text>
      <input 
        class="input" 
        data-name="school" 
        placeholder="请输入学校" 
        value="{{formData.school}}" 
        bindinput="handleInput"
      />
    </view>

    <!-- 学历 -->
    <view class="form-item">
      <text class="label required">学历</text>
      <picker 
        class="picker" 
        range="{{educationOptions}}" 
        data-name="education" 
        value="{{formData.education}}" 
        bindchange="handlePickerChange"
      >
        <view class="picker-text">
          {{educationOptions[formData.education] || '请选择学历'}}
        </view>
      </picker>
    </view>

    <!-- 公司 -->
    <view class="form-item">
      <text class="label required">公司</text>
      <input 
        class="input" 
        data-name="company" 
        placeholder="请输入公司" 
        value="{{formData.company}}" 
        bindinput="handleInput"
      />
    </view>

    <!-- 岗位 -->
    <view class="form-item">
      <text class="label required">岗位</text>
      <input 
        class="input" 
        data-name="position" 
        placeholder="请输入岗位" 
        value="{{formData.position}}" 
        bindinput="handleInput"
      />
    </view>

    <!-- 年限 -->
    <view class="form-item">
      <text class="label required">工作年限</text>
      <input 
        class="input" 
        data-name="workYears" 
        placeholder="请输入工作年限" 
        value="{{formData.workYears}}" 
        bindinput="handleInput"
        type="number"
      />
    </view>

    <!-- 是否参训 -->
    <view class="form-item">
      <text class="label required">是否参训</text>
      <picker 
        class="picker" 
        range="{{trainingOptions}}" 
        data-name="isTrained" 
        value="{{formData.isTrained}}" 
        bindchange="handlePickerChange"
      >
        <view class="picker-text">
          {{trainingOptions[formData.isTrained] || '请选择是否参训'}}
        </view>
      </picker>
    </view>

    <!-- 身份证 -->
    <view class="form-item">
      <text class="label">身份证</text>
      <input 
        class="input" 
        data-name="idCard" 
        placeholder="请输入身份证号（选填）" 
        value="{{formData.idCard}}" 
        bindinput="handleInput"
      />
    </view>

    <!-- 推荐码 -->
    <view class="form-item">
      <text class="label">推荐码</text>
      <input 
        class="input" 
        data-name="recommendCode" 
        placeholder="请输入推荐码（选填）" 
        value="{{formData.recommendCode}}" 
        bindinput="handleInput"
        disabled="{{isRecommendCodeDisabled}}"
      />
      <text wx:if="{{isRecommendCodeDisabled}}" class="disabled-tip">推荐码已锁定</text>
    </view>

    <!-- 提交按钮 -->
    <button 
      class="submit-btn" 
      formType="submit" 
      loading="{{isSubmitting}}"
      disabled="{{isSubmitting}}"
    >
      {{isSubmitting ? '提交中...' : '提交注册'}}
    </button>
  </form>
</view>