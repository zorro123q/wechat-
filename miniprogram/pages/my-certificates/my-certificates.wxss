/* pages/my-certificates/my-certificates.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx 30rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.header-count {
  font-size: 26rpx;
  color: #999;
}

.cert-list {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
}

.cert-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.cert-item:last-child {
  border-bottom: none;
}

.cert-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  margin-right: 30rpx;
  color: #ffffff;
}

.cert-icon.level-1 {
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
}

.cert-icon.level-2 {
  background: linear-gradient(135deg, #faad14 0%, #d48806 100%);
}

.cert-icon.level-3 {
  background: linear-gradient(135deg, #f5222d 0%, #cf1322 100%);
}

.cert-info {
  display: flex;
  flex-direction: column;
}

.cert-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.cert-date {
  font-size: 24rpx;
  color: #999;
}

/* 空状态和加载状态 */
.empty-container, .loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
  color: #999;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #1890ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 26rpx;
  margin-top: 20rpx;
}
