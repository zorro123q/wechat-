<!--pages/my-certificates/my-certificates.wxml-->
<view class="container">
  <view class="header">
    <text class="header-title">我的证书</text>
    <text class="header-count">共 {{certificates.length}} 张</text>
  </view>

  <view class="cert-list" wx:if="{{certificates.length > 0}}">
    <view class="cert-item" wx:for="{{certificates}}" wx:key="_id">
      <view class="cert-icon level-{{item.level}}">
        <text>{{item.level === 3 ? '👑' : item.level === 2 ? '⭐' : '🌱'}}</text>
      </view>
      <view class="cert-info">
        <text class="cert-name">{{item.certName}}</text>
        <text class="cert-date">颁发日期：{{item.formattedDate}}</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-container" wx:if="{{certificates.length === 0 && !loading}}">
    <text class="empty-icon">📜</text>
    <text class="empty-text">暂未获得任何证书</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>
</view>
