.container {
    min-height: 100vh;
    background: #f5f5f5;
    padding: 24rpx 30rpx;
    box-sizing: border-box
}

.card {
    background: #fff;
    border-radius: 16rpx;
    padding: 30rpx;
    box-sizing: border-box
}

.code-img {
    width: 100%
}

.placeholder {
    padding: 80rpx 0;
    text-align: center;
    color: #999;
    font-size: 28rpx
}

.actions {
    margin-top: 24rpx
}

.btn {
    width: 100%;
    height: 88rpx;
    line-height: 72rpx;
    padding-top: 8rpx;
    background: #1890ff;
    color: #fff;
    border-radius: 48rpx;
    font-size: 32rpx
}

.btn::after {
    border: none
}